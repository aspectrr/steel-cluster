# Orchestrator server
PORT=3000

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Kubernetes
K8S_NAMESPACE=browser-sessions
BROWSER_IMAGE=ghcr.io/steel-dev/steel-browser-api:latest
BROWSER_PORT=3000

# Warm pool (set to 0 to disable)
WARM_POOL_SIZE=2

# Session limits
MAX_SESSIONS=100
SESSION_TIMEOUT=1800

# Optional: base path prefix (e.g. "/steel" → routes served under /steel/v1/...)
BASE_PATH=
